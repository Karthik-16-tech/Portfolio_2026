{
  "extends": [
    "stylelint-config-standard"
  ],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "import",
          "source",
          "custom-variant",
          "theme",
          "layer",
          "apply",
          "screen",
          "tailwind",
          "supports"
        ]
      }
    ],
    "function-no-unknown": [
      true,
      {
        "ignoreFunctions": [
          "source"
        ]
      }
    ]
  }
}
